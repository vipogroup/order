rules_version = '2';
// Firebase Console → Firestore → Rules → Publish.
// Spark: Authentication → Sign-in method → Email/Password (חובה). Anonymous לא נדרש לכללים אלה.
// נתונים: inventory/{uid}/... — רק המשתמש המחובר (uid == request.auth.uid) רשאי לנתיב שלו.
// מסמך legacy vipo_state/1985 נשאר לגיבוי/מיגרציה ידנית — לא למחוק עד וידוא מלא.

service cloud.firestore {
  match /databases/{database}/documents {

    function authed() {
      return request.auth != null;
    }

    function ownsInventory(uid) {
      return authed() && request.auth.uid == uid;
    }

    function metaDocOk() {
      return request.resource.data.keys().hasAll(['version', 'savedAt', 'schema'])
        && request.resource.data.version is int
        && request.resource.data.savedAt is string
        && request.resource.data.schema is string;
    }

    function arrivalQtyOk() {
      return request.resource.data.keys().hasOnly(['qty'])
        && (request.resource.data.qty is int || request.resource.data.qty is float);
    }

    match /inventory/{uid} {
      match /sales/{saleId} {
        allow read, delete: if ownsInventory(uid);
        allow create, update: if ownsInventory(uid);
      }
      match /orders/{orderId} {
        allow read, delete: if ownsInventory(uid);
        allow create, update: if ownsInventory(uid);
      }
      match /arrivals/{itemId} {
        allow read, delete: if ownsInventory(uid);
        allow create, update: if ownsInventory(uid) && arrivalQtyOk();
      }
      match /products/{productId} {
        allow read, delete: if ownsInventory(uid);
        allow create, update: if ownsInventory(uid);
      }
      match /payments/{payId} {
        allow read, delete: if ownsInventory(uid) && payId == 'summary';
        allow create, update: if ownsInventory(uid) && payId == 'summary';
      }
      match /settings/{setId} {
        allow read, delete: if ownsInventory(uid) && setId == 'meta';
        allow create, update: if ownsInventory(uid) && setId == 'meta' && metaDocOk();
      }
    }

    match /vipo_state/{docId} {
      allow read: if authed() && docId == '1985';
      allow create, update: if authed()
        && docId == '1985'
        && request.resource.data.keys().hasAll(['version', 'savedAt'])
        && request.resource.data.version is int
        && request.resource.data.savedAt is string;
      allow delete: if false;
    }
  }
}
